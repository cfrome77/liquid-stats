#!/bin/sh
# Pre-commit hook: reset environment.ts ONLY if it has actual values (differs from template)

TEMPLATE="src/environments/environment.template.ts"
TARGET="src/environments/environment.ts"

# Compare files
if ! cmp -s "$TARGET" "$TEMPLATE"; then
  # Only reset if it’s different from the template
  cp "$TEMPLATE" "$TARGET"
  echo "🔒 Reset environment.ts to template placeholder because it had real values"
fi

# If identical to template, do nothing